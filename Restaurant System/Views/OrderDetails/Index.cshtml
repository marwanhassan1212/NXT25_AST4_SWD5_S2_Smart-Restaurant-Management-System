@model IEnumerable<Restaurant_System.Models.OrderDetail>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold">
            Order Details
        </h2>

        <p class="text-muted mb-0">
            Manage items included in customer orders.
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        + Add Item

    </a>

</div>

<div class="card shadow border-0">

    <div class="card-body">

        <table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnitPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Item)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order)
            </th>
                    <th class="text-end" style="width:220px;">
                        Actions
                    </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                            @item.UnitPrice.ToString("0.00")
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.Item.ItemName)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.Order.OrderDisplay)
            </td>
            
                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-warning btn-sm">

                                Edit

                            </a>

                            <a asp-action="Details"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-info btn-sm">

                                Details

                            </a>

                            <a asp-action="Delete"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-danger btn-sm">

                                Delete

                            </a>

                        </td>
       
        </tr>
}
    </tbody>
</table>
    </div>

</div>