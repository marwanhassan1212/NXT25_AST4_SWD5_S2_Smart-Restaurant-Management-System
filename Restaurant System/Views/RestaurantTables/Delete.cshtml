@model Restaurant_System.Models.RestaurantTable

@{
    ViewData["Title"] = "Delete";
}

<div class="mb-4">

    <h2 class="fw-bold text-danger">
        Delete Restaurant Table
    </h2>

    <p class="text-muted">
        Are you sure you want to delete this table?
    </p>

</div>
<div>
    <h4>RestaurantTable</h4>
    <hr />
    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-body p-4">
    <dl class="row">
                        <dt class="col-sm-3 fw-bold">
            @Html.DisplayNameFor(model => model.Capacity)
        </dt>
                        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Capacity)
        </dd>
                        <dt class="col-sm-3 fw-bold">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
                        <dd class="col-sm-9">
                            @if (Model.Status == "Available")
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if (Model.Status == "Occupied")
                            {
                                <span class="badge bg-danger">Occupied</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
        </dd>
    </dl>
                </div>

            </div>

        </div>

    </div>

    <form asp-action="Delete" class="mt-4 text-center">

        <input type="hidden" asp-for="TableId" />

        <button type="submit"
                class="btn btn-danger">

            Delete

        </button>


        <a asp-action="Index"
           class="btn btn-secondary ms-2">

            Cancel

        </a>

    </form>
</div>
