@model RestaurantManagementSystem.ViewModels.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Restaurant Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>

        body {
            background: linear-gradient(135deg,#0f172a,#1e3a8a,#2563eb);
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            font-family:'Segoe UI';
        }

        .login-card{
            width:950px;
            border-radius:25px;
            overflow:hidden;
            box-shadow:0 20px 60px rgba(0,0,0,.35);
            background:white;
        }

        .left-side{
            background:linear-gradient(160deg,#1e40af,#2563eb);
            color:white;
            padding:60px;
            height:100%;
        }

        .left-side h1{
            font-weight:800;
            font-size:40px;
        }

        .left-side p{
            opacity:.9;
            font-size:18px;
        }

        .restaurant-icon{
            font-size:90px;
            margin-bottom:30px;
        }

        .right-side{
            padding:60px;
        }

        .title{
            font-weight:700;
        }

        .form-control{
            height:50px;
            border-radius:12px;
        }

        .btn-login{
            height:50px;
            border-radius:12px;
            font-size:18px;
            font-weight:bold;
        }

        .footer-text{
            color:gray;
            text-align:center;
            margin-top:30px;
            font-size:14px;
        }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="row g-0">

            <div class="col-md-5 left-side d-flex flex-column justify-content-center">

                <div class="restaurant-icon">

                    🍽️

                </div>

                <h1>Restaurant</h1>

                <h3>Management System</h3>

                <p class="mt-4">

                    Smart dashboard for managing orders, tables,
                    employees and customers.

                </p>

            </div>

            <div class="col-md-7 right-side">

                <h2 class="title">

                    Welcome Back 👋

                </h2>

                <p class="text-muted mb-4">

                    Sign in to continue

                </p>

                <form asp-action="Login" method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">

                        <label asp-for="UserName" class="form-label fw-bold"></label>

                        <div class="input-group">

                            <span class="input-group-text">

                                <i class="bi bi-person-fill"></i>

                            </span>

                            <input asp-for="UserName" class="form-control" />

                        </div>

                        <span asp-validation-for="UserName" class="text-danger"></span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Password" class="form-label fw-bold"></label>

                        <div class="input-group">

                            <span class="input-group-text">

                                <i class="bi bi-lock-fill"></i>

                            </span>

                            <input asp-for="Password" class="form-control" />

                        </div>

                        <span asp-validation-for="Password" class="text-danger"></span>

                    </div>

                    <div class="form-check mb-4">

                        <input asp-for="RememberMe" class="form-check-input" />

                        <label asp-for="RememberMe" class="form-check-label"></label>

                    </div>

                    <button class="btn btn-primary btn-login w-100">

                        <i class="bi bi-box-arrow-in-right"></i>

                        Login

                    </button>

                </form>

                <div class="footer-text">

                    © 2026 Restaurant Management System

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @section Scripts
    {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

</body>

</html>