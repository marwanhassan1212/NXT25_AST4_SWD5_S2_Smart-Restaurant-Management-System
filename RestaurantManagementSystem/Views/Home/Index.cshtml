@{
    ViewData["Title"] = "Home Page";
}
<div class="container-fluid">

    <div class="mb-4">

        <h2 class="fw-bold">
            Dashboard
        </h2>

        <p class="text-muted">
            Welcome to the Smart Restaurant Management System.
        </p>

    </div>
                  @* Card 1 *@

    <div class="row g-4">
    <div class="col-lg-3 col-md-6">

        <div class="card shadow-sm border-0 h-100">

            <div class="card-body">

                <h6 class="text-muted">
                    👥 Customers
                </h6>

                <h2 class="fw-bold text-primary">
                    @Model.CustomersCount
                </h2>

            </div>

        </div>

    </div>
                 @* Card 2 *@
    <div class="col-lg-3 col-md-6">

        <div class="card shadow-sm border-0 h-100">

            <div class="card-body">

                <h6 class="text-muted">
                    👨‍🍳 Employees
                </h6>

                <h2 class="fw-bold text-success">
                    @Model.EmployeesCount
                </h2>

            </div>

        </div>

    </div>
                 @* Card 3  *@
    <div class="col-lg-3 col-md-6">

        <div class="card shadow-sm border-0 h-100">

            <div class="card-body">

                <h6 class="text-muted">
                    📦 Orders
                </h6>

                <h2 class="fw-bold text-warning">
                    @Model.OrdersCount
                </h2>

            </div>

        </div>

    </div>


    @* Card 4 *@

    <div class="col-lg-3 col-md-6">

        <div class="card shadow-sm border-0 h-100">

            <div class="card-body">

                <h6 class="text-muted">
                    💰 Total Revenue
                </h6>

                <h2 class="fw-bold text-danger">
                    @Model.TotalRevenue.ToString("0.00") EGP
                </h2>

            </div>

        </div>

    </div>



</div>
    <div class="row g-4 mt-1">

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <h6 class="text-muted">
                        💵 Today's Revenue
                    </h6>

                    <h2 class="fw-bold text-success">
                        @Model.TodayRevenue.ToString("0.00") EGP
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <h6 class="text-muted">
                        🧾 Today's Orders
                    </h6>

                    <h2 class="fw-bold text-primary">
                        @Model.TodayOrders
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <h6 class="text-muted">
                        🟢 Available Tables
                    </h6>

                    <h2 class="fw-bold text-success">
                        @Model.AvailableTables
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <h6 class="text-muted">
                        🔴 Reserved Tables
                    </h6>

                    <h2 class="fw-bold text-danger">
                        @Model.ReservedTables
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <div class="row g-4 mt-2">

        <!-- Orders Last 7 Days -->
        <div class="col-lg-7">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="fw-bold mb-0">
                        📈 Orders Last 7 Days
                    </h5>

                </div>

                <div class="card-body">

                    <div style="height:320px">

                        <canvas id="ordersLineChart"></canvas>

                    </div>

                </div>

            </div>

        </div>

        <!-- Orders Status -->
        <div class="col-lg-5">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="fw-bold mb-0">
                        🍩 Orders Status
                    </h5>

                </div>

                <div class="card-body d-flex justify-content-center align-items-center">

                    <div style="width:280px;height:280px;">

                        <canvas id="ordersStatusChart"></canvas>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row g-4 mt-3">

        <!-- Recent Orders -->

        <div class="col-lg-8">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="fw-bold mb-0">
                        📋 Recent Orders
                    </h5>

                </div>

                <div class="card-body p-0">

                    <div class="table-responsive">

                        <table class="table table-hover mb-0 align-middle">

                            <thead class="table-light">

                                <tr>

                                    <th>#</th>

                                    <th>Customer</th>

                                    <th>Status</th>

                                    <th>Total</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>

                                        <td>@order.OrderId</td>

                                        <td>@order.Customer.FullName</td>

                                        <td>@order.OrderStatus</td>

                                        <td>@order.TotalAmount.ToString("0.00") EGP</td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

        <!-- Top Selling Items -->

        <div class="col-lg-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="fw-bold mb-0">
                        🔥 Top Selling Items
                    </h5>

                </div>

                <div class="card-body">

                    @if (Model.TopSellingItems != null && Model.TopSellingItems.Count > 0)
                    {
                        @foreach (var item in Model.TopSellingItems)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <div>

                                    <h6 class="mb-1 fw-semibold">
                                        @item.ItemName
                                    </h6>

                                    <small class="text-muted">
                                        Sold @item.QuantitySold items
                                    </small>

                                </div>

                                <span class="badge bg-success rounded-pill fs-6">
                                    @item.QuantitySold
                                </span>

                            </div>

                            <hr />
                        }
                    }
                    else
                    {
                        <p class="text-center text-muted mb-0">
                            No sales yet.
                        </p>
                    }

                </div>

            </div>

        </div>

        <div class="row g-4 mt-2">

            <div class="col-lg-6">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-header bg-white border-0">

                        <h5 class="fw-bold mb-0">
                            💳 Average Order Value
                        </h5>

                    </div>

                    <div class="card-body d-flex justify-content-center align-items-center">

                        <div class="text-center">

                            <h1 class="fw-bold text-success">
                                @Model.AverageOrderValue.ToString("0.00")
                            </h1>

                            <p class="text-muted mb-0">
                                EGP per Order
                            </p>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-6">

                <div class="card shadow-sm border-0 h-100">

                    <div class="card-header bg-white border-0">

                        <h5 class="fw-bold mb-0">
                            🏆 Top Employee
                        </h5>

                    </div>

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>

                            <h4 class="fw-bold mb-1">
                                @Model.TopEmployeeName
                            </h4>

                            <p class="text-muted mb-0">
                                Employee with the highest number of orders
                            </p>

                        </div>

                        <div class="text-end">

                            <h2 class="fw-bold text-primary">
                                @Model.TopEmployeeOrders
                            </h2>

                            <small class="text-muted">
                                Orders
                            </small>

                        </div>

                    </div>

                </div>

            </div>

        </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const lineCtx = document.getElementById('ordersLineChart');

    new Chart(lineCtx, {

        type: 'line',

        data: {

            labels: [

                @foreach (var day in Model.Last7Days)
                {
                        <text>'@day',</text>
                }

            ],

            datasets: [{

                label: 'Orders',

                data: [

                    @foreach (var count in Model.OrdersPerDay)
                    {
                            <text>@count,</text>
                    }

                ],

                borderColor: '#0d6efd',

                backgroundColor: 'rgba(13,110,253,.15)',

                fill: true,

                tension: .4

            }]

        },

        options: {

            responsive: true,

            maintainAspectRatio: false,

            plugins: {

                legend: {

                    display: false

                }

            },

            scales: {

                y: {

                    beginAtZero: true,

                    ticks: {

                        precision: 0

                    }

                }

            }

        }

    });

        const doughnutCtx = document.getElementById('ordersStatusChart');

    new Chart(doughnutCtx, {

        type: 'doughnut',

        data: {

            labels: [

                'Pending',

                'Preparing',

                'Completed',

                'Cancelled'

            ],

            datasets: [{

                data: [

                    @Model.PendingOrders,

                    @Model.PreparingOrders,

                    @Model.CompletedOrders,

                    @Model.CancelledOrders

                ],

                backgroundColor: [

                    '#0d6efd',

                    '#ffc107',

                    '#198754',

                    '#dc3545'

                ],

                borderWidth: 2

            }]

        },

        options: {

            responsive: true,

            maintainAspectRatio: false,

            cutout: '65%',

            plugins: {

                legend: {

                    position: 'bottom'

                }

            }

        }

    });

</script>


