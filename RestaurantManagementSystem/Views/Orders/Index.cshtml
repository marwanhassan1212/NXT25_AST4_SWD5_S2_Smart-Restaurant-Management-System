@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<RestaurantManagementSystem.Models.Order>

@{
    ViewData["Title"] = "Index";
}


<div class="card shadow-lg border-0 mb-4">

    <div class="card-body d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="bi bi-receipt-cutoff text-primary"></i>

                Orders

            </h2>

            <p class="text-muted mb-0">

                Manage restaurant orders.

            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg">

            <i class="bi bi-plus-circle"></i>

            New Order

        </a>

    </div>

</div>

<partial name="_Alerts" />

<div class="card shadow border-0">

    <div class="card-body">

        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-end mb-4">

            <div class="col-md-4">

                <input name="searchString"
                       value="@ViewBag.SearchString"
                       class="form-control"
                       placeholder="🔍 Search Order..." />

            </div>

            <div class="col-md-auto d-flex gap-2">

                <button class="btn btn-primary px-4">

                    Search

                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary px-4">

                    Reset

                </a>

            </div>

        </form>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewBag.NameSort"
                           asp-route-searchString="@ViewBag.SearchString"
                           class="text-decoration-none text-light">

                            Order Date

                        </a>
                    </th>
                    <th>
                        Order Status
                    </th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewBag.NameSort"
                           asp-route-searchString="@ViewBag.SearchString"
                           class="text-decoration-none text-light">

                            Total Amount

                        </a>
                    </th>
                    <th>
                        Customer
                    </th>
                    <th>
                        Employee
                    </th>
                    <th>
                        Table
                    </th>
                    <th class="text-center" style="width:180px;">

                        <i class="bi bi-gear-fill me-1"></i>

                        Actions

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @item.OrderDate.ToString("dd/MM/yyyy")
                        </td>
                        <td>

                            @if (item.OrderStatus == "Pending")
                            {
                                <span class="badge bg-secondary px-3 py-2">

                                    Pending

                                </span>
                            }
                            else if (item.OrderStatus == "Preparing")
                            {
                                <span class="badge bg-warning text-dark px-3 py-2">

                                    Preparing

                                </span>
                            }
                            else if (item.OrderStatus == "Completed")
                            {
                                <span class="badge bg-success px-3 py-2">

                                    Completed

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger px-3 py-2">

                                    Cancelled

                                </span>
                            }

                        </td>
                        <td>
                            <span class="fw-bold text-success">

                                @item.TotalAmount.ToString("N2") EGP

                            </span>
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Customer.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Employee.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Table.TableDisplay)
                        </td>
                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.OrderId"
                               class="btn btn-warning btn-sm rounded-pill me-1">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.OrderId"
                               class="btn btn-info btn-sm rounded-pill me-1 text-white">

                                <i class="bi bi-eye"></i>

                            </a>

                            @if (item.OrderStatus == "Pending")
                            {
                                <form asp-action="Complete"
                                      asp-route-id="@item.OrderId"
                                      method="post"
                                      class="d-inline">

                                    <button class="btn btn-success btn-sm rounded-pill me-1">

                                        <i class="bi bi-check-lg"></i>

                                    </button>

                                </form>
                            }

                            <a asp-action="Delete"
                               asp-route-id="@item.OrderId"
                               class="btn btn-danger btn-sm rounded-pill">

                                <i class="bi bi-trash"></i>

                            </a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-center mt-4">

            @Html.PagedListPager(
            Model,
            page => Url.Action("Index", new
            {
                page,
                searchString = ViewBag.SearchString
            }))

        </div>
    </div>

</div>