@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<RestaurantManagementSystem.Models.RestaurantTable>

@{
    ViewData["Title"] = "Index";
}

<div class="card shadow-lg border-0 mb-4">

    <div class="card-body d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="bi bi-grid-3x3-gap-fill text-primary"></i>

                Restaurant Tables

            </h2>

            <p class="text-muted mb-0">

                Manage all restaurant tables.

            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg">

            <i class="bi bi-plus-circle"></i>

            Add Table

        </a>

    </div>

</div>
<partial name="_Alerts" />

<div class="card shadow border-0">

    <div class="card-body">

        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-end mb-4">

            <div class="col-md-4">

                <input name="searchString"
                       value="@ViewBag.SearchString"
                       class="form-control"
                       placeholder="🔍 Search Table..." />

            </div>

            <div class="col-md-auto d-flex gap-2">

                <button class="btn btn-primary px-4">

                    Search

                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary px-4">

                    Reset

                </a>

            </div>

        </form>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewBag.NameSort"
                           asp-route-searchString="@ViewBag.SearchString"
                           class="text-decoration-none text-light">

                                Capacity

                        </a>
                    </th>
                    <th>
                       Status
                    </th>
                    <th class="text-center" style="width:180px;">

                        <i class="bi bi-gear-fill me-1"></i>

                        Actions

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Capacity)
                        </td>
                        <td>

                            @if (item.Status == "Available")
                            {
                                <span class="badge bg-success px-3 py-2">

                                    Available

                                </span>
                            }
                            else if (item.Status == "Reserved")
                            {
                                <span class="badge bg-warning text-dark px-3 py-2">

                                    Reserved

                                </span>
                            }

                        </td>
                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.TableId"
                               class="btn btn-warning btn-sm rounded-pill me-2"
                               title="Edit">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.TableId"
                               class="btn btn-info btn-sm rounded-pill me-2 text-white"
                               title="Details">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.TableId"
                               class="btn btn-danger btn-sm rounded-pill"
                               title="Delete">

                                <i class="bi bi-trash"></i>

                            </a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-center mt-4">

            @Html.PagedListPager(
            Model,
            page => Url.Action("Index", new
            {
                page,
                searchString = ViewBag.SearchString
            }))

        </div>
    </div>

</div>