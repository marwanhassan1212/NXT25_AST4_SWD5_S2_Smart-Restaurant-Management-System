<div class="row mb-4">

    <div class="col-md-6">

        <input type="text"
               id="searchProduct"
               class="form-control form-control-lg"
               placeholder="🔍 Search Menu Item..." />

    </div>

</div>
<div class="col-md-3">

    <select id="categoryFilter" class="form-select form-select-lg">
            class="form-select form-select-lg">

        <option value="all">

            All Categories

        </option>

        @foreach (var category in ViewBag.Categories)
        {
            <option value="@category.CategoryId">

                @category.CategoryName

            </option>
        }

    </select>

</div>
<div class="row">
<div class="col-lg-8">

        <div class="row mt-3">

        @foreach (var item in Model)
        {
                <div class="col-md-4 mb-4 product-container">
                    <div class="card product-card h-100 shadow-sm"
                         data-id="@item.ItemId"
                         data-name="@item.ItemName.ToLower()"
                         data-category="@item.Category.CategoryId"
                         data-price="@item.Price">

                        <div class="card-body text-center">

                            <h1 class="mb-3">🍽</h1>

                            <h5 class="fw-bold">@item.ItemName</h5>

                            <p class="text-muted">@item.Category.CategoryName</p>

                            <h4 class="text-success fw-bold">@item.Price.ToString("0.00") EGP</h4>

                        </div>

                    </div>

            </div>
        }

    </div>

</div>

<div class="col-lg-4">

        <div class="card shadow-lg border-0 sticky-top" style="top:90px;">

        <div class="card-header bg-primary text-white">

            <h4 class="mb-0">

                🛒 Current Order

            </h4>

        </div>

        <div class="card-body">

                <div class="order-items-container">

                    <div id="orderItems">
                    </div>

                </div>

            <hr>

            <div class="mb-3">

                <label class="form-label">

                    Customer

                </label>

                    <select id="customerId" class="form-select">

                    @foreach (var customer in ViewBag.Customers)
                    {
                        <option value="@customer.CustomerId">

                            @customer.FullName

                        </option>
                    }

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">

                    Table

                </label>

                    <select id="tableId" class="form-select">

                    @foreach (var table in ViewBag.Tables)
                    {
                        <option value="@table.TableId">
                            @table.TableDisplay
                        </option>
                    }

                </select>

            </div>

            <hr>

            <h3>

                Total

                    <span id="totalPrice"
                          class="float-end text-success">

                        0.00 EGP

                    </span>

            </h3>

                <button id="completeOrderBtn"
                        class="btn btn-success w-100 mt-3">

                    <span id="completeOrderText">
                        Complete Order
                    </span>

                    <span id="completeOrderSpinner"
                          class="spinner-border spinner-border-sm ms-2 d-none">
                    </span>

                </button>

                <button id="cancelOrderBtn"
                        class="btn btn-outline-danger w-100 mt-2">

                    <i class="bi bi-x-circle"></i>

                    Cancel Order

                </button>


        </div>

    </div>

</div>
</div>
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">

    <div id="successToast"
         class="toast align-items-center text-bg-success border-0"
         role="alert">

        <div class="d-flex">

            <div class="toast-body">

                ✅ Order Completed Successfully.

            </div>

            <button type="button"
                    class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast">
            </button>

        </div>

    </div>

</div>

<div class="modal fade"
     id="cancelOrderModal"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-danger text-white">

                <h5 class="modal-title">

                    Cancel Current Order

                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body text-center">

                <i class="bi bi-exclamation-triangle-fill text-danger"
                   style="font-size:60px;"></i>

                <h4 class="mt-3">

                    Are you sure?

                </h4>

                <p class="text-muted">

                    All selected items will be removed.

                </p>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    No

                </button>

                <button id="confirmCancelOrder"
                        class="btn btn-danger">

                    Yes, Cancel Order

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        let order=[];

        document.querySelectorAll(".product-card").forEach(card=>{

            card.addEventListener("click",()=>{

                let id=card.dataset.id;
                let name=card.dataset.name;
                let price=parseFloat(card.dataset.price);

                let item=order.find(x=>x.id==id);

                if(item){

                    item.qty++;

                }
                else{

                    order.push({

                        id:id,
                        name:name,
                        price:price,
                        qty:1

                    });

                }

                renderOrder();

            });

        });

          function increaseQty(id){

            let item=order.find(x=>x.id==id);

            item.qty++;

            renderOrder();

        }

        function decreaseQty(id){

            let item=order.find(x=>x.id==id);

            item.qty--;

            if(item.qty<=0){

                order=order.filter(x=>x.id!=id);

            }

            renderOrder();

        }

        function removeItem(id){

            order=order.filter(x=>x.id!=id);

            renderOrder();

        }

        function renderOrder(){
                  

            let container=document.getElementById("orderItems");

            container.innerHTML="";

            let total=0;

            order.forEach(item=>{

                total+=item.price*item.qty;

                      container.innerHTML += `

        <div class="card mb-2 border-0 shadow-sm">

            <div class="card-body p-2">

                <div class="d-flex justify-content-between">

                    <strong>${item.name}</strong>

                    <button
                        class="btn btn-sm btn-danger"
                        onclick="removeItem(${item.id})">

                        <i class="bi bi-trash"></i>

                    </button>

                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">

                    <div>

                        <button
                            class="btn btn-outline-secondary btn-sm"
                            onclick="decreaseQty(${item.id})">

                            -

                        </button>

                        <span class="mx-2 fw-bold">

                            ${item.qty}

                        </span>

                        <button
                            class="btn btn-outline-success btn-sm"
                            onclick="increaseQty(${item.id})">

                            +

                        </button>

                    </div>

                    <strong>

                        ${(item.price*item.qty).toFixed(2)} EGP

                    </strong>

                </div>

            </div>

        </div>

        `;

            });

            if(order.length==0){

                container.innerHTML="<p class='text-center text-muted'>No Items Yet</p>";

            }

            document.getElementById("totalPrice").innerText=total.toFixed(2)+" EGP";

        }
                document
        .getElementById("completeOrderBtn")
        .addEventListener("click", completeOrder);

        async function completeOrder(){

              const btn = document.getElementById("completeOrderBtn");
                const text = document.getElementById("completeOrderText");
                const spinner = document.getElementById("completeOrderSpinner");

                   if(order.length==0)
                   {

                    alert("Please add items first.");

                    return;
                   
                   }
                     btn.disabled = true;
                     text.innerText = "Saving...";
                     spinner.classList.remove("d-none");

            let data={

                customerId:parseInt(document.getElementById("customerId").value),

                tableId:parseInt(document.getElementById("tableId").value),

                items:order.map(x=>({

                    itemId:parseInt(x.id),

                    quantity:x.qty

                }))

            };
          
            let response=await fetch("/POS/CompleteOrder",{

                method:"POST",

                headers:{

                    "Content-Type":"application/json"

                },

                body:JSON.stringify(data)

            });

                          if(response.ok){

            let result = await response.json();

            const toast = new bootstrap.Toast(
                document.getElementById("successToast")
            );

            toast.show();

            order = [];

            renderOrder();

            document.getElementById("customerId").selectedIndex = 0;
            document.getElementById("tableId").selectedIndex = 0;
            document.getElementById("searchProduct").value = "";
            document.getElementById("categoryFilter").value = "all";

            filterProducts();

            let option = document.querySelector(
                `#tableId option[value="${data.tableId}"]`
            );

            if(option){

                option.remove();

            }
                    setTimeout(() => {

            window.location.href =
                "/Invoice/Index?id=" + result.orderId;

        }, 1000);

        }
        else{

            let error = await response.text();

            alert(error);

        }

        btn.disabled = false;
        text.innerText = "Complete Order";
        spinner.classList.add("d-none");
        }

        

          function filterProducts()
          
          {

            let search = document
                .getElementById("searchProduct")
                .value
                .toLowerCase();

            let category = document
                .getElementById("categoryFilter")
                .value;

            document
                .querySelectorAll(".product-container")
                .forEach(card=>{

                    let product = card.querySelector(".product-card");

                    let name = product.dataset.name;

                    let productCategory = product.dataset.category;

                    let matchSearch = name.includes(search);

                    let matchCategory =
                        category == "all" ||
                        productCategory == category;

                    if(matchSearch && matchCategory){

                        card.style.display = "";

                    }
                    else{

                        card.style.display = "none";

                    }

                });

        }
 
        document
        .getElementById("searchProduct")
        .addEventListener("keyup", filterProducts);

        document
        .getElementById("categoryFilter")
        .addEventListener("change", filterProducts);


              document
        .getElementById("cancelOrderBtn")
        .addEventListener("click",()=>{

            if(order.length==0)
                return;

            const modal=new bootstrap.Modal(
                document.getElementById("cancelOrderModal")
            );

            modal.show();

        });

                document
        .getElementById("confirmCancelOrder")
        .addEventListener("click",()=>{

            order=[];

            renderOrder();

            bootstrap.Modal
                .getInstance(
                    document.getElementById("cancelOrderModal")
                )
                .hide();

        });

    </script>
}