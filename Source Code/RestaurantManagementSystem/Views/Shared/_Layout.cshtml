﻿
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restaurant_System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Restaurant_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">
</head>
<body>
    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm fixed-top"
             style="background:#1E293B; height:70px; z-index:1050;">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold fs-4"
                   asp-controller="Home"
                   asp-action="Index">

                    🍽 Restaurant Management

                </a>

                <div class="d-flex align-items-center">

                    @if (User.Identity!.IsAuthenticated)
                    {
                        <span class="text-light me-4">

                            Welcome,
                            <strong>@User.Identity.Name</strong>

                        </span>

                        <div class="rounded-circle bg-primary d-flex justify-content-center align-items-center"
                             style="width:40px;height:40px;">

                            <span class="text-white fw-bold">

                                @User.Identity.Name.Substring(0, 1).ToUpper()

                            </span>

                        </div>

                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="btn btn-outline-danger btn-sm ms-3">

                            Logout

                        </a>
                    }

                </div>

            </div>

        </nav>

    </header>

    <div class="container-fluid p-0">

        <div class="row g-0">

            <!-- Sidebar -->
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="col-md-2">
                    <div class="sidebar text-white shadow-lg position-fixed">

                        <h5 class="text-uppercase text-secondary fw-bold small mb-4">

                            Main Menu

                        </h5>

                        <div class="sidebar-menu">

                            <div class="menu-section">

                                <small class="menu-title">

                                    GENERAL

                                </small>

                                <a asp-controller="Home"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-speedometer2"></i>

                                    Dashboard

                                </a>

                            </div>

                            <div class="menu-section mt-4">

                                <small class="menu-title">

                                    MANAGEMENT

                                </small>

                                <a asp-controller="Roles"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-shield-lock-fill"></i>

                                    Roles

                                </a>

                                <a asp-controller="Employees"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-person-badge-fill"></i>

                                    Employees

                                </a>

                                <a asp-controller="Customers"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-people-fill"></i>

                                    Customers

                                </a>

                            </div>

                            <div class="menu-section mt-4">

                                <small class="menu-title">

                                    RESTAURANT

                                </small>

                                <a asp-controller="Categories"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-folder-fill"></i>

                                    Categories

                                </a>

                                <a asp-controller="MenuItems"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-cup-hot-fill"></i>

                                    Menu Items

                                </a>

                                <a asp-controller="RestaurantTables"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-grid-3x3-gap-fill"></i>

                                    Tables

                                </a>




                            </div>

                            <div class="menu-section mt-4">

                                <small class="menu-title">

                                    SALES

                                </small>

                                <a asp-controller="POS"
                                   asp-action="Index"
                                   class="menu-link">

                                    

                                    💳 POS

                                </a>

                                <a asp-controller="Orders"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-receipt-cutoff"></i>

                                    Orders

                                </a>

                                <a asp-controller="OrderDetails"
                                   asp-action="Index"
                                   class="menu-link">

                                    <i class="bi bi-box-seam-fill"></i>

                                    Order Details

                                </a>

                            </div>

                        </div>

                </div>

            </div>
            }

            <!-- Main -->

            <div class="@(User.Identity!.IsAuthenticated ? "col-md-10 offset-md-2" : "col-md-12") p-4 fade-card"
                 style="padding-top:30px;">

                @RenderBody()

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>