@model RestaurantManagementSystem.Models.OrderDetail

@{
    ViewData["Title"] = "Delete";
}
<div class="mb-4">

    <h2 class="fw-bold text-danger">
        Delete Order Item
    </h2>

    <p class="text-muted">
        Are you sure you want to remove this item from the order?
    </p>

</div>

<div>
    <h4>OrderDetail</h4>
    <hr />
    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-body p-4">
    <dl class="row">
                        <dt class="col-sm-3 fw-bold">
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>
                        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Quantity)
        </dd>
                        <dt class="col-sm-3 fw-bold">
            @Html.DisplayNameFor(model => model.UnitPrice)
        </dt>
                        <dd class="col-sm-9">
                            @Model.UnitPrice.ToString("0.00")
        </dd>
                        <dt class="col-sm-3 fw-bold">
                            Menu Item
                        </dt>
                        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Item.ItemName)
        </dd>
                        <dt class="col-sm-3 fw-bold">
                            Order
                        </dt>
        
                        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Order.OrderDisplay)
        </dd>
    </dl>
                </div>

            </div>

        </div>

    </div>

    <form asp-action="Delete" class="mt-4 text-center">

        <input type="hidden" asp-for="OrderId" />
        <input type="hidden" asp-for="ItemId" />

        <button type="submit"
                class="btn btn-danger">

            Delete

        </button>


        <a asp-action="Index"
           class="btn btn-secondary ms-2">

            Cancel

        </a>

    </form>
</div>