@model IEnumerable<RestaurantManagementSystem.Models.OrderDetail>

@{
    ViewData["Title"] = "Index";
}

<div class="card shadow-lg border-0 mb-4">

    <div class="card-body d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="bi bi-box-seam-fill text-primary"></i>

                Order Details

            </h2>

            <p class="text-muted mb-0">

                Manage products included in customer orders.

            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg">

            <i class="bi bi-plus-circle"></i>

            Add Item

        </a>

    </div>

</div>
<partial name="_Alerts" />

<div class="card shadow border-0">

    <div class="card-body">

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Quantity)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.UnitPrice)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Item)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Order)
                    </th>
                    <th class="text-center" style="width:180px;">

                        <i class="bi bi-gear-fill me-1"></i>

                        Actions

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Quantity)
                        </td>
                        <td>
                            @item.UnitPrice.ToString("0.00")
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Item.ItemName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Order.OrderDisplay)
                        </td>
                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-warning btn-sm rounded-pill me-2"
                               title="Edit">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <a asp-action="Details"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-info btn-sm rounded-pill me-2 text-white"
                               title="Details">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-orderId="@item.OrderId"
                               asp-route-itemId="@item.ItemId"
                               class="btn btn-danger btn-sm rounded-pill"
                               title="Delete">

                                <i class="bi bi-trash"></i>

                            </a>

                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>