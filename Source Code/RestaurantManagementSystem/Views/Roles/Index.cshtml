@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<RestaurantManagementSystem.Models.Role>

@{
    ViewData["Title"] = "Index";
}

<div class="card shadow-lg border-0 mb-4">

    <div class="card-body d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="bi bi-shield-lock-fill text-primary"></i>

                Roles

            </h2>

            <p class="text-muted mb-0">

                Manage employee roles and permissions.

            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg">

            <i class="bi bi-plus-circle"></i>

            Add Role

        </a>

    </div>

</div>
<partial name="_Alerts" />

<div class="card shadow border-0">

    <div class="card-body">

        <form asp-action="Index" method="get" class="row g-3 align-items-end mb-4">

            <div class="col-md-5">

                <input type="text"
                       name="searchString"
                       value="@ViewBag.SearchString"
                       class="form-control"
                       placeholder="🔍 Search Role..." />

            </div>

            <div class="col-md-3 d-flex gap-2">

                <button type="submit" class="btn btn-primary">

                    Search

                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">

                    Reset

                </a>

            </div>

        </form>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>

                        <a asp-action="Index"
                           asp-route-sortOrder="@ViewBag.NameSort"
                           asp-route-searchString="@ViewBag.SearchString"
                           class="text-decoration-none text-light">

                            Role Name

                        </a>

                    </th>
                    <th class="text-center" style="width:180px;">

                        <i class="bi bi-gear-fill me-1"></i>

                        Actions

                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.RoleName)
                        </td>
                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.RoleId"
                               class="btn btn-warning btn-sm rounded-pill me-2">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.RoleId"
                               class="btn btn-info btn-sm rounded-pill me-2 text-white">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.RoleId"
                               class="btn btn-danger btn-sm rounded-pill">

                                <i class="bi bi-trash"></i>

                            </a>

                        </td>

                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-center mt-4">

            @Html.PagedListPager(
            Model,
            page => Url.Action("Index", new
            {
                page,
                searchString = ViewBag.SearchString
            }))

        </div>
    </div>

</div>